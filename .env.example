# ── Evolution API ──────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=finbot
# Fase 7.1: segredo esperado no header 'apikey' de todo POST em /webhook.
# Configure o mesmo valor na Evolution API (webhook custom headers). Sem
# isso definido, o endpoint fica aberto (comportamento anterior à Fase 7).
EVOLUTION_WEBHOOK_SECRET=

# ── OpenAI (Vision + Whisper) ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase / PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres

# Fase 7.5 (exclusão de conta "de verdade"): apagar o login no Supabase Auth
# exige a Admin API do projeto. SUPABASE_URL é a URL base do projeto (sem
# /auth/... no final, ex: https://<ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY fica em Supabase > Project Settings > API >
# service_role (secret). NUNCA coloque essa chave no finbot-web (frontend) —
# só aqui, como variável de ambiente do servidor (Railway). Sem ela, a
# exclusão de conta ainda apaga os dados financeiros normalmente, só não
# remove o login (ver providers/supabase_admin.py).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Servidor (Railway injeta automaticamente) ──────────────────
PORT=5000

# ── API web (Fase 4.3) ──────────────────────────────────────────
# JWKS do projeto Supabase — valida o JWT que o finbot-web manda em
# Authorization: Bearer <token>. URL padrão do Supabase:
# https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
# Domínio do finbot-web autorizado por CORS a chamar /api/*
FINBOT_WEB_ORIGIN=http://localhost:3000

# ── Observabilidade (Fase 7.3) ──────────────────────────────────
LOG_LEVEL=INFO
