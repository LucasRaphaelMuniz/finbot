# ── Evolution API ──────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=finbot
# Fase 7.1: segredo esperado no header 'apikey' de todo POST em /webhook.
# Configure o mesmo valor na Evolution API (webhook custom headers). Sem
# isso definido, o endpoint fica aberto (comportamento anterior à Fase 7).
EVOLUTION_WEBHOOK_SECRET=

# ── OpenAI (Vision + Whisper) ──────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Supabase / PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres

# Fase 7.5 (exclusão de conta "de verdade"): apagar o login no Supabase Auth
# exige a Admin API do projeto. SUPABASE_URL é a URL base do projeto (sem
# /auth/... no final, ex: https://<ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY fica em Supabase > Project Settings > API >
# service_role (secret). NUNCA coloque essa chave 